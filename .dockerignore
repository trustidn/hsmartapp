# =============================================================================
# HSmart Docker Build Context - Exclusions
# =============================================================================
# Reduces image size and speeds up builds
# =============================================================================

# Version control
.git
.gitignore
.gitattributes

# Dependencies
node_modules
frontend/node_modules
**/node_modules

# Environment and secrets
.env
.env.*

# Docker files (avoid recursive copy)
Dockerfile*
docker-compose*
.dockerignore

# Logs and temporary
*.log
tmp
cache
temp
*.tmp

# User uploads (never bake into image)
uploads
backups

# Build artifacts
frontend/dist
backend/bin
**/dist
**/bin
*.exe

# Tests
**/__tests__
**/*_test.go
**/*.test
coverage.html
*.out

# IDE & OS
.idea
.vscode
*.swp
*.swo
.DS_Store
Thumbs.db

# Docs & misc
docs
*.md
