# =============================================================================
# HSmart Production Environment Variables
# =============================================================================
# Copy to .env and fill in values. Never commit .env to git.
#
# Usage: docker compose -f docker-compose.production.yml up -d
# =============================================================================

# --- Database (PostgreSQL on HOST) ---
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=hsmartapp_user
DB_PASSWORD=P4ssword90901
DB_NAME=hsmartapp_saas

# --- Security (REQUIRED) ---
# Generate: openssl rand -hex 32
JWT_SECRET=

# --- Application ---
HTTP_ADDR=:8080
STATIC_DIR=/app/static
UPLOAD_DIR=/app/uploads

# Base URL for uploads (e.g. https://hsmart.app). Empty = relative path.
BASE_URL=

# --- Redis (optional - empty = no cache) ---
REDIS_ADDR=
REDIS_PASSWORD=
