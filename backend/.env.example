# Development lokal (tanpa Docker). Copy ke .env atau export manual.
# Production: WAJIB set semua variable berikut. Jangan gunakan nilai default di production.

# --- WAJIB (Production) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hsmart?sslmode=disable
JWT_SECRET=rahasia-dev
# JWT_SECRET production: generate dengan: openssl rand -hex 32

# --- Opsional ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
HTTP_ADDR=:8080

# --- Production (untuk upload & branding) ---
BASE_URL=
# BASE_URL: base URL publik untuk upload (contoh: https://api.hsmart.app). Kosong = relative path.
UPLOAD_DIR=./uploads
# UPLOAD_DIR: direktori penyimpanan file (logos, payment-proofs)
