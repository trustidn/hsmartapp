# =============================================================================
# HSmart Production Environment Variables
# =============================================================================
# Copy to .env and fill in. Used by: docker compose -f docker-compose.production.yml
#
# For production deployment, copy to .env in repo root before running compose.
# =============================================================================

# --- Database (PostgreSQL on HOST) ---
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=hsmartapp_user
DB_PASSWORD=P4ssword90901
DB_NAME=hsmartapp_saas

# --- Security (REQUIRED - generate: openssl rand -hex 32) ---
JWT_SECRET=

# --- Application ---
BASE_URL=

# --- Redis (optional, leave empty to disable) ---
REDIS_ADDR=
REDIS_PASSWORD=
